# Server runtime environment file example.
# Use this file as a template for /opt/daoyou/.env.production or local .env.

PORT=3000

# AI provider
PROVIDER_CHOOSE=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_USE=deepseek-v4-flash
DEEPSEEK_MODEL_FAST_USE=deepseek-v4-flash

# Optional providers
ARK_API_KEY=
ARK_BASE_URL=
ARK_MODEL_USE=
ARK_MODEL_FAST_USE=
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODEL_USE=
KIMI_MODEL_FAST_USE=
ALIBABA_API_KEY=
ALIBABA_BASE_URL=
ALIBABA_MODEL_USE=
ALIBABA_MODEL_FAST_USE=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_USE=
OPENROUTER_MODEL_FAST_USE=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
FAST_MODEL=

# Persistence and jobs
DATABASE_URL=postgresql://user:password@db-host:5432/daoyou
REDIS_URL=redis://:password@redis-host:6379/0
# Required in production for /internal/cron/* bearer auth and manual backfills.
CRON_SECRET=replace-with-a-random-secret

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_URL=https://daoyou.example.com
BETTER_AUTH_DB_SCHEMA=better_auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# WeChat Mini Program
WECHAT_MINI_APPID=wx3b4802aee0f5b7db
WECHAT_MINI_SECRET=your-wechat-mini-app-secret

# WeChat Mini Program
WECHAT_MINI_APPID=wx3b4802aee0f5b7db
WECHAT_MINI_SECRET=your-wechat-mini-app-secret

# Captcha
TURNSTILE_SECRET_KEY=

# Admin
ADMIN_EMAILS=
ADMIN_BROADCAST_BATCH_SIZE=20

# Mail
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="万界道友官方 <noreply@example.com>"

# Feature flags
ENABLE_LLM_NAMING=
DISABLE_LLM_NAMING=

# Frontend public build variables
# Configure these in GitHub Actions Environment/Repository vars, not in the
# server runtime env file passed to `docker run --env-file`.
# VITE_TURNSTILE_SITE_KEY=your-public-turnstile-site-key
